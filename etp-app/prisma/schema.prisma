generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LocalUser {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          String   @default("user")
  is_active     Boolean  @default(true)
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("local_users")
}

model SalesPlanning {
  id                    String    @id @default(cuid())
  ot                    String?
  clte_interno          String?
  cliente               String?
  codigo_plazo          String?
  equipo                String?
  modelo_capacidad      String?
  camion                String?
  modelo                String?
  vin                   String?
  llegada               DateTime?
  inicio                DateTime?
  entregado             Boolean   @default(false)
  venta                 String?
  color_eq              String?
  oc                    String?
  factura               String?
  cotizacion            Boolean   @default(false)
  correo                String?
  patente               String?
  neumatico_de_repuesto String?
  n_recepcion           String?
  color_cabina          String?
  atraso                Int?
  prioridad             Int?      @default(5)
  fecha_entrega_real    DateTime?
  planning_buffer_days  Int?
  planning_buffer_note  String?
  planning_buffer_at    DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  created_by            String?
  updated_by            String?

  optimized          SalesPlanningOptimized[]
  process_schedules  OptimizedProcessSchedule[]
  buffer_adjustments PlanningBufferAdjustment[]

  @@map("sales_planning")
}

model PlanningRun {
  id         String   @id @default(cuid())
  version    Int      @default(1)
  status     String   @default("ACTIVE")
  created_at DateTime @default(now())
  created_by String?
  notes      String?

  optimized         SalesPlanningOptimized[]
  process_schedules OptimizedProcessSchedule[]
  special_days      SpecialWorkingDay[]

  @@map("planning_run")
}

model SalesPlanningOptimized {
  id                String         @id @default(cuid())
  sales_planning_id String?
  planning_run_id   String?
  sales_planning    SalesPlanning? @relation(fields: [sales_planning_id], references: [id], onDelete: SetNull)
  planning_run      PlanningRun?   @relation(fields: [planning_run_id], references: [id], onDelete: SetNull)
  position          Int            @default(0)
  start_date        DateTime?
  end_date          DateTime?
  prioridad         Int?
  codigo_plazo      String?
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  @@map("sales_planning_optimized")
}

model LeadTimeByCode {
  id                 String   @id @default(cuid())
  codigo_plazo       String
  descripcion_equipo String?
  proceso            String
  duracion_dias      Int
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([codigo_plazo, proceso])
  @@map("lead_time_by_code")
}

model ProcessCapacity {
  id                String   @id @default(cuid())
  proceso           String   @unique
  orden             Int
  capacidad_por_dia Int
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("process_capacity")
}

model OptimizedProcessSchedule {
  id                String        @id @default(cuid())
  sales_planning_id String
  planning_run_id   String?
  proceso           String
  orden             Int
  slot              Int           @default(1)
  start_date        DateTime
  end_date          DateTime
  duration_days     Int
  created_at        DateTime      @default(now())
  sales_planning    SalesPlanning @relation(fields: [sales_planning_id], references: [id], onDelete: Cascade)
  planning_run      PlanningRun?  @relation(fields: [planning_run_id], references: [id], onDelete: SetNull)

  @@map("optimized_process_schedule")
}

model PlanningBufferAdjustment {
  id                String        @id @default(cuid())
  sales_planning_id String
  buffer_days       Int           // new total buffer after this change
  prev_buffer_days  Int?          // total buffer before this change
  delta_days        Int           @default(0) // buffer_days - prev_buffer_days
  note              String?
  created_at        DateTime      @default(now())
  created_by        String?
  sales_planning    SalesPlanning @relation(fields: [sales_planning_id], references: [id], onDelete: Cascade)

  @@map("planning_buffer_adjustment")
}

model SpecialWorkingDay {
  id               String       @id @default(cuid())
  date             DateTime
  type             String       @default("WEEKEND_WORKING")
  description      String?
  created_at       DateTime     @default(now())
  created_by       String?
  planning_run_id  String?
  used_in_planning Boolean      @default(false)
  planning_run     PlanningRun? @relation(fields: [planning_run_id], references: [id], onDelete: SetNull)

  @@map("special_working_day")
}
